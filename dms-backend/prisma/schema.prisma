generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================================
// GROUP 1: MASTER DATA
// ==========================================

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  users       User[]
  pr_forms    PRForm[]

  @@map("departments")
}

model Position {
  id          String   @id @default(uuid())
  name        String   @unique
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  users       User[]

  @@map("positions")
}

model DocumentType {
  id          String   @id @default(uuid())
  type_name   String   @unique
  prefix      String   @unique // e.g. "PR", "PO", "CERT"
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  documents       Document[]
  approval_matrix ApprovalMatrix[]
  running_numbers RunningNumber[]

  @@map("document_types")
}

// ==========================================
// GROUP 2: USERS & PERMISSIONS
// ==========================================

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  is_active   Boolean  @default(true)

  users           User[]
  permissions     RolePermission[]
  approval_matrix ApprovalMatrix[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  module      String   // Document | User | Workflow | Master Data
  action      String   // View | Add | Edit | Delete | Export
  description String?

  roles       RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  role_id       String
  permission_id String

  role          Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
  @@map("role_permissions")
}

model User {
  id                   String   @id @default(uuid())
  username             String   @unique
  email                String   @unique
  password_hash        String
  first_name           String
  last_name            String
  
  department_id        String?
  position_id          String?
  role_id              String?
  
  signature_image_path String?
  is_active            Boolean  @default(true)
  reset_token          String?
  reset_token_expiry   DateTime?
  
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  // Relations
  department           Department? @relation(fields: [department_id], references: [id])
  position             Position?   @relation(fields: [position_id], references: [id])
  role                 Role?       @relation(fields: [role_id], references: [id])
  
  documents_created    Document[]
  pr_forms_requested   PRForm[]
  cert_issued_to       CertificateForm[] @relation("IssuedTo")
  cert_issued_by       CertificateForm[] @relation("IssuedBy")
  document_versions    DocumentVersion[]
  workflow_steps       WorkflowStep[]
  notifications        Notification[]
  audit_logs           AuditLog[]

  @@map("users")
}

// ==========================================
// GROUP 3: DOCUMENTS & VERSIONS
// ==========================================

enum DocumentStatus {
  Draft
  Pending
  Approved
  Rejected
  Cancelled
}

model Document {
  id          String         @id @default(uuid())
  doc_number  String         @unique // e.g., PR-2026-0001
  title       String
  
  type_id     String
  creator_id  String
  
  status      DocumentStatus @default(Draft)
  is_deleted  Boolean        @default(false)
  
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  // Relations
  type        DocumentType   @relation(fields: [type_id], references: [id])
  creator     User           @relation(fields: [creator_id], references: [id])
  
  pr_form     PRForm?
  po_form     POForm?
  cert_form   CertificateForm?
  
  versions    DocumentVersion[]
  workflow    Workflow?
  notifications Notification[]

  @@map("documents")
}

model PRForm {
  id             String     @id @default(uuid())
  document_id    String     @unique
  
  requested_date DateTime?
  required_date  DateTime?
  
  requester_id   String
  department_id  String
  
  purpose        String?    @db.Text
  total_amount   Decimal    @default(0) @db.Decimal(10, 2)

  // Relations
  document       Document   @relation(fields: [document_id], references: [id], onDelete: Cascade)
  requester      User       @relation(fields: [requester_id], references: [id])
  department     Department @relation(fields: [department_id], references: [id])
  
  items          PRFormItem[]

  @@map("pr_forms")
}

model PRFormItem {
  id             String   @id @default(uuid())
  pr_form_id     String
  
  item_name      String
  quantity       Int
  unit           String?
  unit_price     Decimal  @db.Decimal(10, 2)
  total_price    Decimal  @db.Decimal(10, 2)
  remark         String?  @db.Text

  pr_form        PRForm   @relation(fields: [pr_form_id], references: [id], onDelete: Cascade)

  @@map("pr_form_items")
}

model POForm {
  id             String   @id @default(uuid())
  document_id    String   @unique
  
  vendor_name    String
  vendor_contact String?
  
  delivery_date  DateTime?
  payment_terms  String?
  total_amount   Decimal  @default(0) @db.Decimal(10, 2)

  document       Document @relation(fields: [document_id], references: [id], onDelete: Cascade)
  items          POFormItem[]

  @@map("po_forms")
}

model POFormItem {
  id             String   @id @default(uuid())
  po_form_id     String
  
  item_name      String
  quantity       Int
  unit           String?
  unit_price     Decimal  @db.Decimal(10, 2)
  vat            Decimal  @default(7) @db.Decimal(5, 2)
  total_price    Decimal  @db.Decimal(10, 2)
  remark         String?  @db.Text

  po_form        POForm   @relation(fields: [po_form_id], references: [id], onDelete: Cascade)

  @@map("po_form_items")
}

model CertificateForm {
  id               String   @id @default(uuid())
  document_id      String   @unique
  
  certificate_type String
  
  issued_to_id     String
  issued_by_id     String
  
  issue_date       DateTime?
  expiry_date      DateTime?
  detail           String?  @db.Text

  document         Document @relation(fields: [document_id], references: [id], onDelete: Cascade)
  issued_to        User     @relation("IssuedTo", fields: [issued_to_id], references: [id])
  issued_by        User     @relation("IssuedBy", fields: [issued_by_id], references: [id])

  @@map("certificate_forms")
}

model DocumentVersion {
  id               String   @id @default(uuid())
  document_id      String
  
  version_number   Int      // 1, 2, 3...
  file_path        String
  file_size        String?
  file_extension   String?
  
  uploaded_by_id   String
  remarks          String?  @db.Text
  
  created_at       DateTime @default(now())

  document         Document @relation(fields: [document_id], references: [id], onDelete: Cascade)
  uploaded_by      User     @relation(fields: [uploaded_by_id], references: [id])

  @@map("document_versions")
}

// ==========================================
// GROUP 4: WORKFLOW & SUPPORT
// ==========================================

model ApprovalMatrix {
  id               String   @id @default(uuid())
  document_type_id String
  
  step_order       Int      // 1 to 4
  required_role_id String

  document_type    DocumentType @relation(fields: [document_type_id], references: [id], onDelete: Cascade)
  required_role    Role         @relation(fields: [required_role_id], references: [id])

  @@map("approval_matrix")
}

enum WorkflowStatus {
  Pending
  Approved
  Rejected
}

model Workflow {
  id             String         @id @default(uuid())
  document_id    String         @unique
  
  total_steps    Int
  current_step   Int            @default(1)
  status         WorkflowStatus @default(Pending)
  
  created_at     DateTime       @default(now())

  document       Document       @relation(fields: [document_id], references: [id], onDelete: Cascade)
  steps          WorkflowStep[]

  @@map("workflows")
}

model WorkflowStep {
  id                String         @id @default(uuid())
  workflow_id       String
  
  step_order        Int
  approver_id       String
  
  status            WorkflowStatus @default(Pending)
  action_date       DateTime?
  comment           String?        @db.Text
  
  signature_applied Boolean        @default(false)
  return_to_step    Int?

  workflow          Workflow       @relation(fields: [workflow_id], references: [id], onDelete: Cascade)
  approver          User           @relation(fields: [approver_id], references: [id])

  @@map("workflow_steps")
}

model Notification {
  id             String   @id @default(uuid())
  user_id        String
  document_id    String?
  
  message        String   @db.Text
  is_read        Boolean  @default(false)
  
  created_at     DateTime @default(now())

  user           User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  document       Document? @relation(fields: [document_id], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model RunningNumber {
  id               String   @id @default(uuid())
  document_type_id String   @unique
  
  prefix           String
  year_format      String   // e.g., "YYYY", "YY"
  current_number   Int      @default(0)
  padding_length   Int      @default(4)

  document_type    DocumentType @relation(fields: [document_type_id], references: [id], onDelete: Cascade)

  @@map("running_numbers")
}

enum AuditAction {
  Login
  Upload
  Download
  View
  Edit
  Delete
  Approve
  Reject
  Signature
}

model AuditLog {
  id          String      @id @default(uuid())
  user_id     String?
  
  action      AuditAction
  module      String
  target_id   String?
  details     Json?
  
  ip_address  String?
  created_at  DateTime    @default(now())

  user        User?       @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}
